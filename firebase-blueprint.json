{
  "entities": {
    "tip": {
      "title": "Tech Tip",
      "description": "A short tech tip for the community",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "createdAt"]
    },
    "update": {
      "title": "STEA Update",
      "description": "Latest news and updates from STEA",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "deal": {
      "title": "Tech Deal",
      "description": "A curated tech deal or discount",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "url": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "url", "createdAt"]
    },
    "course": {
      "title": "Course",
      "description": "A course offered by STEA",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "string" },
        "level": { "type": "string" },
        "price": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "createdAt"]
    },
    "user": {
      "title": "User",
      "description": "A registered user of the STEA platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "product": {
      "title": "Product",
      "description": "An electronic product in the Duka",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "oldPrice": { "type": "string" },
        "icon": { "type": "string" },
        "imageUrl": { "type": "string" },
        "badge": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "payment_mpesa": { "type": "string", "description": "Vodacom M-Pesa Number" },
        "payment_airtel": { "type": "string", "description": "Airtel Money Number" },
        "payment_tigo": { "type": "string", "description": "Tigo Pesa Number" },
        "payment_bank": { "type": "string", "description": "Bank Account Details" },
        "payment_lipa": { "type": "string", "description": "Lipa Namba Details" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "url", "createdAt"]
    },
    "website": {
      "title": "Website",
      "description": "A curated website or tool",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "imageUrl": { "type": "string" },
        "bg": { "type": "string" },
        "meta": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "url", "createdAt"]
    },
    "prompt": {
      "title": "AI Prompt",
      "description": "A curated AI prompt for the Prompt Lab",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "prompt": { "type": "string" },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "imageUrl": { "type": "string" },
        "howToUse": { "type": "string" },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iconUrl": { "type": "string" },
              "toolUrl": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "prompt", "category", "createdAt"]
    },
    "site_setting": {
      "title": "Site Setting",
      "description": "General settings for a website section",
      "type": "object",
      "properties": {
        "data": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["data"]
    },
    "faq": {
      "title": "FAQ",
      "description": "A frequently asked question",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" },
        "order": { "type": "integer" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "answer", "order", "isActive"]
    },
    "sponsored_ad": {
      "title": "Sponsored Ad",
      "description": "A paid advertisement",
      "type": "object",
      "properties": {
        "adTitle": { "type": "string" },
        "clientName": { "type": "string" },
        "contactPerson": { "type": "string" },
        "clientPhone": { "type": "string" },
        "clientWhatsApp": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "adImage": { "type": "string" },
        "shortCaption": { "type": "string" },
        "ctaText": { "type": "string" },
        "ctaLink": { "type": "string" },
        "adType": { "type": "string", "enum": ["popup", "inline_banner", "sponsored_card", "floating_cta"] },
        "placement": { "type": "string" },
        "targetPages": { "type": "array", "items": { "type": "string" } },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "active", "paused", "expired"] },
        "priority": { "type": "integer" },
        "totalImpressions": { "type": "integer" },
        "totalClicks": { "type": "integer" },
        "maxDailyViews": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "required": ["adTitle", "clientName", "adType", "status", "priority"]
    },
    "order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "customerPhone": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "productType": { "type": "string", "enum": ["subscription", "one_time_access", "digital_product", "service"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentReference": { "type": "string" },
        "paymentProofImage": { "type": "string" },
        "orderStatus": { "type": "string", "enum": ["pending", "awaiting_payment_review", "approved", "rejected", "completed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "verified", "failed", "refunded"] },
        "deliveryStatus": { "type": "string", "enum": ["not_sent", "processing", "sent", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["orderId", "userId", "customerName", "productId", "amount", "orderStatus", "createdAt"]
    },
    "payment": {
      "title": "Payment",
      "description": "A payment record for review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "usernameEmail": { "type": "string" },
        "phone": { "type": "string" },
        "transactionId": { "type": "string" },
        "service": { "type": "string" },
        "planType": { "type": "string" },
        "amountPaid": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviewedBy": { "type": "string" },
        "reviewNotes": { "type": "string" }
      },
      "required": ["userId", "usernameEmail", "amountPaid", "paymentMethod", "status", "submittedAt"]
    },
    "payment_setting": {
      "title": "Payment Setting",
      "description": "Configuration for a payment method",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "qrImage": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "accountNumber": { "type": "string" }
      },
      "required": ["name", "enabled"]
    },
    "subscription": {
      "title": "Subscription",
      "description": "A customer subscription",
      "type": "object",
      "properties": {
        "subscriptionId": { "type": "string" },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "planName": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "daysLeft": { "type": "integer" },
        "status": { "type": "string", "enum": ["active", "expiring_soon", "expired", "cancelled"] },
        "renewalCount": { "type": "integer" },
        "reminderSent3Days": { "type": "boolean" },
        "reminderSent1Day": { "type": "boolean" },
        "expiredNoticeSent": { "type": "boolean" },
        "autoRenew": { "type": "boolean" },
        "lastPaymentDate": { "type": "string", "format": "date-time" },
        "nextRenewalDate": { "type": "string", "format": "date-time" },
        "accessActive": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "required": ["subscriptionId", "orderId", "userId", "status", "startDate", "accessActive"]
    },
    "delivery": {
      "title": "Delivery",
      "description": "A delivery task for access",
      "type": "object",
      "properties": {
        "deliveryId": { "type": "string" },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "productName": { "type": "string" },
        "accessType": { "type": "string", "enum": ["login_credentials", "invite_link", "download_link", "whatsapp_delivery", "manual_activation"] },
        "accessDetails": { "type": "string" },
        "supplierName": { "type": "string" },
        "supplierContact": { "type": "string" },
        "deliveryStatus": { "type": "string", "enum": ["pending", "processing", "sent", "customer_confirmed"] },
        "sentAt": { "type": "string", "format": "date-time" },
        "handledBy": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["deliveryId", "orderId", "userId", "deliveryStatus"]
    },
    "message_template": {
      "title": "Message Template",
      "description": "Editable message templates for customer communication",
      "type": "object",
      "properties": {
        "templateId": { "type": "string" },
        "name": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["templateId", "name", "content"]
    },
    "vpn_config": {
      "title": "VPN Config",
      "description": "A VPN configuration document in the pool",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "subscriptionLink": { "type": "string" },
        "type": { "type": "string", "enum": ["trial", "paid"] },
        "status": { "type": "string", "enum": ["available", "assigned", "quarantine"] },
        "assignedTo": { "type": "string" },
        "quarantineUntil": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["label", "subscriptionLink", "type", "status"]
    },
    "vpn_instruction": {
      "title": "VPN Instruction",
      "description": "Setup instructions for a specific device type",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "appLink": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "troubleshooting": { "type": "string" },
        "videoLink": { "type": "string" }
      },
      "required": ["appName", "appLink", "steps"]
    },
    "chaba_product": {
      "title": "Chaba Product",
      "description": "A product for the China marketplace",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "groupPrice": { "type": "number" },
        "groupMinQty": { "type": "number" },
        "isFlashSale": { "type": "boolean" },
        "isTrending": { "type": "boolean" },
        "flashSaleEnd": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["color", "size", "other"] },
              "options": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "category": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "price"]
    }
  },
  "firestore": {
    "tips": { "schema": "tip", "description": "Collection of tech tips" },
    "updates": { "schema": "update", "description": "Collection of STEA updates" },
    "deals": { "schema": "deal", "description": "Collection of tech deals" },
    "courses": { "schema": "course", "description": "Collection of courses" },
    "users": { "schema": "user", "description": "Collection of registered users" },
    "products": { "schema": "product", "description": "Collection of products in Duka" },
    "websites": { "schema": "website", "description": "Collection of curated websites" },
    "prompts": { "schema": "prompt", "description": "Collection of AI prompts" },
    "site_settings": { "schema": "site_setting", "description": "Collection for site-wide settings documents" },
    "faqs": { "schema": "faq", "description": "Collection of FAQ items" },
    "sponsored_ads": { "schema": "sponsored_ad", "description": "Collection of sponsored ads" },
    "orders": { "schema": "order", "description": "Collection of customer orders" },
    "payments": { "schema": "payment", "description": "Collection of customer payments" },
    "paymentSettings": { "schema": "payment_setting", "description": "Collection of payment settings" },
    "subscriptions": { "schema": "subscription", "description": "Collection of customer subscriptions" },
    "deliveries": { "schema": "delivery", "description": "Collection of customer deliveries" },
    "chaba_products": { "schema": "chaba_product", "description": "Collection of China marketplace products" },
    "chaba_orders": { "schema": "order", "description": "Collection of China marketplace orders" },
    "message_templates": { "schema": "message_template", "description": "Collection of message templates" },
    "vpnConfigs": { "schema": "vpn_config", "description": "Pool of VPN configurations" },
    "vpnInstructions": { "schema": "vpn_instruction", "description": "Device-specific setup instructions" },
    "adminSettings": { "schema": "site_setting", "description": "General admin settings" },
    "posts": { "schema": "update", "description": "General posts collection" },
    "website_solutions": { "schema": "website", "description": "Collection of curated solutions" },
    "prompt_lab": { "schema": "prompt", "description": "Collection of AI prompts" },
    "video_courses": { "schema": "course", "description": "Collection of video courses" }
  }
}
