# GOOGLE_API_KEY: Required for the STEA AI Assistant backend.
# Add your paid Google API key here.
GOOGLE_API_KEY="your_paid_google_api_key_here"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Sports Data Provider (API-Football)
SPORTS_API_KEY="your_api_football_key_here"

# Google AdSense Publisher ID
VITE_ADSENSE_PUBLISHER_ID="ca-pub-XXXXXXXXXXXXXXX"

# Production NECTA API base URL, for example:
# VITE_NECTA_API_BASE_URL="https://stea-api-xxxxx-uc.a.run.app"
VITE_NECTA_API_BASE_URL=

# Firebase Cloud Messaging public web push certificate key.
# Use the public key from Firebase Console > Project settings > Cloud Messaging.
VITE_FIREBASE_VAPID_KEY=

# Private CEO workspace second-factor session gate.
VITE_CEO_ACCESS_CODE=
# Optional: override/add the CEO Firebase Auth identity used by /ceo.
VITE_CEO_EMAIL=
VITE_CEO_UID=
